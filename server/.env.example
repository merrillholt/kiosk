# Building Directory Server — Environment Variables
#
# Copy this file to .env and adjust values as needed, or set variables
# directly in the systemd service unit with:
#
#   sudo systemctl edit directory-server
#   [Service]
#   Environment=VARIABLE=value
#
# All variables are optional; defaults are shown.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# TCP port the Node.js server listens on. nginx proxies port 80 to this.
# PORT=3000

# Admin password for /admin and write APIs.
# REQUIRED in production. If unset, server defaults to "kiosk" and exits
# unless KIOSK_ALLOW_DEFAULT_PASSWORD=true is explicitly set (dev only).
# KIOSK_ADMIN_PASSWORD=change-me

# Dev-only override to allow default password "kiosk".
# Never enable this in production.
# KIOSK_ALLOW_DEFAULT_PASSWORD=true

# Login rate limit settings (per client IP).
# Defaults: 10 attempts / 15 minutes, then blocked for 15 minutes.
# KIOSK_LOGIN_MAX_ATTEMPTS=10
# KIOSK_LOGIN_WINDOW_MS=900000
# KIOSK_LOGIN_BLOCK_MS=900000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file.
# KIOSK_DB=/home/merrill/building-directory/server/directory.db

# ---------------------------------------------------------------------------
# File uploads (background images)
# ---------------------------------------------------------------------------

# Temporary directory where multer saves uploaded image files.
# Lost on reboot; persist-upload.sh copies files to KIOSK_UPLOADS_LOWER.
# KIOSK_TEMP_DIR=/tmp/kiosk-uploads

# Persistent uploads directory on the overlayroot ext4 lower layer.
# Served as /uploads by the Express static middleware.
# KIOSK_UPLOADS_LOWER=/media/root-ro/home/merrill/building-directory/server/uploads

# Command used to copy/delete files in the overlayroot lower layer.
# Space-separated; the script receives 'copy <src> <filename>' or 'delete <filename>'.
# Set to a mock script path during local development/testing.
# KIOSK_PERSIST_CMD=sudo /usr/local/bin/persist-upload.sh

# ---------------------------------------------------------------------------
# Kiosk display client deployment
# ---------------------------------------------------------------------------

# JSON array of kiosk display machines. Update IPs when machines are provisioned.
# Each object must have: id (integer), name (string), ip (string), user (string).
# KIOSK_CLIENTS=[{"id":1,"name":"Kiosk 1","ip":"192.168.1.127","user":"merrill"},{"id":2,"name":"Kiosk 2","ip":"192.168.1.128","user":"merrill"},{"id":3,"name":"Kiosk 3","ip":"192.168.1.129","user":"merrill"}]

# Path to the SSH private key used by kiosk-deploy.sh to connect to kiosk machines.
# The corresponding public key must be in ~/.ssh/authorized_keys on each kiosk.
# Generated automatically (ed25519) on first access to GET /api/kiosks/deploy-pubkey.
# KIOSK_SSH_KEY=/home/merrill/.ssh/kiosk_deploy_key

# URL that kiosk display machines use to reach this server.
# Auto-detected from the server's first non-loopback IPv4 address if not set.
# Override if the server has multiple network interfaces or uses a hostname.
# KIOSK_SERVER_URL=http://192.168.1.100

# Warm-standby server URL used by kiosk clients when primary is unreachable
# for 5 minutes at startup.
# KIOSK_SERVER_URL_STANDBY=http://192.168.1.81
